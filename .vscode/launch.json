{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Dev (Electrobun)",
      "runtimeExecutable": "/home/void/.bun/bin/bun",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "env": {
        "LD_LIBRARY_PATH": "/usr/lib/x86_64-linux-gnu"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
