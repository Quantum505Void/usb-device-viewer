# USB Device Viewer - Linux udev 规则
#
# 默认情况下 /dev/hidraw* 只有 root 可读。
# 安装此文件后普通用户无需 sudo 即可访问 HID 设备。
#
# 安装方法：
#   sudo cp 99-usb-hid.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
#   （重新插拔设备使规则生效）

# 允许所有用户读写 hidraw 设备
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", MODE="0666"

# 或者限定特定用户组（推荐）：
# KERNEL=="hidraw*", SUBSYSTEM=="hidraw", GROUP="plugdev", MODE="0660"
# 然后将用户加入 plugdev 组：sudo usermod -aG plugdev $USER
